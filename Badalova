<!DOCTYPE html>
<html lang="az">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zuleykha Badalova</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ivory:#FAF7F1;
    --ink:#292620;
    --ink-soft:#6b665c;
    --sage:#435B3F;
    --sage-deep:#334631;
    --sage-soft:#E5E9DC;
    --clay:#C1783F;
    --line:#DAD3C3;
  }

  *{ box-sizing:border-box; }

  html{
    height:100%;
  }

  html,body{
    margin:0;
    padding:0;
    width:100%;
    background:var(--ivory);
    color:var(--ink);
    font-family:'Manrope', sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  body{
    min-height:100vh;
    min-height:100dvh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:clamp(20px, 5vw, 56px) clamp(14px, 4vw, 24px);
    background-image:
      radial-gradient(circle at 50% 0%, rgba(67,91,63,0.06), transparent 60%),
      radial-gradient(circle at 100% 100%, rgba(193,120,63,0.05), transparent 55%);
  }

  .card{
    width:100%;
    max-width:400px;
    background:#fff;
    border:1px solid var(--line);
    border-radius:22px;
    padding:clamp(26px, 6vw, 38px) clamp(20px, 6vw, 30px) clamp(22px, 5vw, 30px);
    position:relative;
    box-shadow:0 30px 60px -30px rgba(41,38,32,0.25);
    opacity:0;
    transform:translateY(18px) scale(0.98);
    animation:card-enter .7s cubic-bezier(.16,.8,.3,1) forwards;
    animation-delay:.05s;
  }

  @keyframes card-enter{
    to{
      opacity:1;
      transform:translateY(0) scale(1);
    }
  }

  /* language toggle */
  .lang-toggle{
    display:flex;
    justify-content:flex-end;
    margin-bottom:18px;
  }
  .lang-toggle-inner{
    display:inline-flex;
    border:1px solid var(--line);
    border-radius:999px;
    overflow:hidden;
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.06em;
  }
  .lang-toggle-inner button{
    border:none;
    background:transparent;
    padding:6px 13px;
    cursor:pointer;
    color:var(--ink-soft);
    font-family:inherit;
    font-size:inherit;
    letter-spacing:inherit;
    transition:background .2s ease, color .2s ease;
    -webkit-tap-highlight-color: transparent; /* Убирает синюю вспышку на смартфонах */
  }
  .lang-toggle-inner button.active{
    background:var(--sage);
    color:#fff;
  }
  .lang-toggle-inner button:focus-visible,
  .cta:focus-visible{
    outline:2px solid var(--clay);
    outline-offset:2px;
  }

  /* monogram / plate */
  .plate{
    width:clamp(92px, 24vw, 112px);
    height:clamp(92px, 24vw, 112px);
    margin:0 auto 20px;
    position:relative;
  }
  .plate svg{ width:100%; height:100%; display:block; }
  .plate .ring{ fill:none; stroke:var(--line); stroke-width:1; }
  .plate .tick{ stroke:var(--clay); stroke-width:2; stroke-linecap:round; }
  .plate .core{ fill:var(--sage-soft); stroke:var(--sage); stroke-width:1.5; }
  .plate .mono{
    font-family:'Fraunces', serif;
    font-size:34px;
    font-weight:600;
    fill:var(--sage-deep);
  }

  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.10em;
    text-transform:uppercase;
    color:var(--sage-deep);
    background:var(--sage-soft);
    padding:5px 14px;
    border-radius:999px;
  }
  .eyebrow-wrap{ text-align:center; min-height: 26px; }

  h1{
    text-align:center;
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:clamp(24px, 6.5vw, 32px);
    line-height:1.15;
    margin:16px 0 6px;
    color:var(--ink);
  }

  .subtitle{
    text-align:center;
    font-size:clamp(13.5px, 3.6vw, 14.5px);
    color:var(--ink-soft);
    margin:0 0 clamp(20px, 5vw, 28px);
    line-height:1.5;
  }

  /* nutrition-facts styled credentials panel */
  .facts{
    border-top:4px solid var(--ink);
    border-bottom:2px solid var(--ink);
    padding:10px 0 2px;
    margin-bottom:clamp(20px, 5vw, 26px);
  }
  .facts-title{
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--ink-soft);
    margin-bottom:8px;
  }
  .facts-row{
    display:flex;
    flex-wrap:wrap;
    justify-content:space-between;
    align-items:baseline;
    gap:2px 14px;
    padding:9px 0;
    border-top:1px solid var(--line);
  }
  .facts-row:first-of-type{ border-top:none; }
  .facts-label{
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--ink-soft);
    white-space:nowrap;
    padding-top:2px;
  }
  .facts-value{
    font-size:clamp(13px, 3.6vw, 14px);
    font-weight:600;
    text-align:right;
    color:var(--ink);
    flex:1 1 auto;
    min-width:0;
  }

  .actions{
    display:flex;
    flex-direction:column;
    gap:12px;
  }

  .cta{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    height:clamp(48px, 12vw, 52px);
    padding:0 12px;
    border-radius:12px;
    text-decoration:none;
    font-weight:600;
    font-size:clamp(13.5px, 3.6vw, 15px);
    letter-spacing:0.01em;
    transition:transform .15s ease, box-shadow .15s ease, background .15s ease;
  }
  .cta:hover{ transform:translateY(-1px); }
  .cta svg{ width:19px; height:19px; flex:none; }

  .cta.primary{
    background:var(--sage);
    color:#fff;
    box-shadow:0 10px 24px -10px rgba(67,91,63,0.55);
  }
  .cta.primary:hover{ background:var(--sage-deep); }

  .cta.secondary{
    background:#fff;
    color:var(--ink);
    border:1.5px solid var(--ink);
  }
  .cta.secondary:hover{ background:var(--ink); color:#fff; }
  .cta.secondary:hover svg{ stroke:#fff; }

  /* Корректная логика переключения языков */
  [data-lang] { display: none !important; }
  span[data-lang].is-active { display: inline !important; }
  .eyebrow[data-lang].is-active { display: inline-block !important; }

  @media (prefers-reduced-motion: reduce){
    .cta{ transition:none; }
    .card{
      animation:none;
      opacity:1;
      transform:none;
    }
  }

  @media (min-width: 640px){
    .card{ max-width:430px; }
  }

  @media (max-width: 340px){
    .plate{ margin-bottom:14px; }
  }
</style>
</head>
<body>

<div class="card">

  <div class="lang-toggle">
    <div class="lang-toggle-inner" role="group" aria-label="Language / Dil / Язык">
      <button type="button" data-set-lang="az" class="active">AZ</button>
      <button type="button" data-set-lang="ru">RU</button>
    </div>
  </div>

  <div class="plate" aria-hidden="true">
    <svg viewBox="0 0 120 120">
      <circle class="ring" cx="60" cy="60" r="57"></circle>
      <g class="tick">
        <line x1="60" y1="6" x2="60" y2="14"></line>
        <line x1="60" y1="106" x2="60" y2="114"></line>
        <line x1="6" y1="60" x2="14" y2="60"></line>
        <line x1="106" y1="60" x2="114" y2="60"></line>
      </g>
      <circle class="core" cx="60" cy="60" r="44"></circle>
      <text x="60" y="72" text-anchor="middle" class="mono">ZB</text>
    </svg>
  </div>

  <div class="eyebrow-wrap">
    <span class="eyebrow" data-lang="az">Qidalanma üzrə mütəxəssis</span>
    <span class="eyebrow" data-lang="ru">Специалист по питанию</span>
  </div>

  <h1>Zuleykha Badalova</h1>

  <p class="subtitle">
    <span data-lang="az">Həkim, qidalanma üzrə mütəxəssis</span>
    <span data-lang="ru">Врач, специалист по питанию</span>
  </p>

  <div class="facts">
    <div class="facts-title">
      <span data-lang="az">Təhsil</span>
      <span data-lang="ru">Образование</span>
    </div>
    <div class="facts-row">
      <span class="facts-label">01</span>
      <span class="facts-value">Azerbaijan Medical University</span>
    </div>
    <div class="facts-row">
      <span class="facts-label">02</span>
      <span class="facts-value">Sechenov University</span>
    </div>
  </div>

  <div class="actions">
    <a class="cta primary" target="_blank" rel="noopener"
       href="https://www.instagram.com/zuleykhabadalova?igsh=MXg3YWU3M3EwMDR2ZQ==">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <rect x="3" y="3" width="18" height="18" rx="5"></rect>
        <circle cx="12" cy="12" r="4.2"></circle>
        <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"></circle>
      </svg>
      <span data-lang="az">İnstaqram</span>
      <span data-lang="ru">Мой Instagram</span>
    </a>

    <a class="cta secondary" target="_blank" rel="noopener"
       href="https://wa.me/message/KOJIFSFH2QLDA1">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M20 11.5a8 8 0 1 1-3.6-6.7L20 4l-1.1 3.5c.7 1.2 1.1 2.6 1.1 4z"></path>
        <path d="M9 10c.3 1.8 1.9 3.4 3.7 3.7"></path>
      </svg>
      <span data-lang="az">Yazılmaq üçün</span>
      <span data-lang="ru">Для записи</span>
    </a>
  </div>

</div>

<script>
  function setLang(lang){
    document.querySelectorAll('[data-lang]').forEach(function(el){
      el.classList.toggle('is-active', el.getAttribute('data-lang') === lang);
    });
    document.querySelectorAll('.lang-toggle-inner button').forEach(function(btn){
      btn.classList.toggle('active', btn.getAttribute('data-set-lang') === lang);
    });
    document.documentElement.setAttribute('lang', lang);
  }

  document.querySelectorAll('.lang-toggle-inner button').forEach(function(btn){
    btn.addEventListener('click', function(e){ 
      e.preventDefault();
      setLang(btn.getAttribute('data-set-lang')); 
    });
  });
  
  // Установка начального языка
  setLang('az');
</script>

</body>
</html>
